{
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "Database": "loyalty"
  },
  "ApiKey": {
    "Key": ""
  },
  "Kafka": {
    "BootstrapServers": "localhost:9094",
    "GroupId": "loyalty-transactions",
    "Topic": "webmoney.transactions.created"
  },
  "BonusOutboxJob": {
    "BatchSize": 200,
    "PollingInterval": "00:00:03"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath = '/health' and (StatusCode is null or StatusCode = 200)"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
