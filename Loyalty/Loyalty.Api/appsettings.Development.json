{
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017/?directConnection=true",
    "Database": "loyalty_dev"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9094",
    "GroupId": "loyalty-transactions-dev",
    "Topic": "webmoney.transactions.created"
  },
  "ApiKey": {
    "Key": "dev-loyalty-api-key"
  },
  "WebMoneyService": {
    "BaseUrl": "http://localhost:5003",
    "ApiKey": "dev-loyalty-api-key"
  },
  "BonusOutboxJob": {
    "BatchSize": 200,
    "PollingInterval": "00:00:03"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath = '/health' and (StatusCode is null or StatusCode = 200)"
        }
      }
    ]
  }
}
